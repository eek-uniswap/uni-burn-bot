# ── Ethereum (mainnet) ────────────────────────────────────────────────────────
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# ERC-20 token contract address and burn recipient to monitor
TOKEN_ADDRESS=0x1f9840a85d5aF5bf1D1762F925BDADdC4201F984
RECIPIENT_ADDRESS=0x000000000000000000000000000000000000dEaD

# Amount to monitor for mainnet direct burns (4000 UNI in wei)
AMOUNT=4000000000000000000000

# ── L2 chains (optional — omit any chain to disable monitoring for it) ────────
# Each chain uses a dedicated Firepit contract; contract addresses are hardcoded.
UNICHAIN_RPC_URL=https://unichain.gateway.tenderly.co/YOUR_KEY
BASE_RPC_URL=https://base.gateway.tenderly.co/YOUR_KEY
OPTIMISM_RPC_URL=https://optimism.gateway.tenderly.co/YOUR_KEY
ARBITRUM_RPC_URL=https://arbitrum.gateway.tenderly.co/YOUR_KEY

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_CHANNEL="#your-channel"

# ── Optional ──────────────────────────────────────────────────────────────────
# Polling interval in seconds (default: 30)
POLL_INTERVAL=30
# Path to SQLite database file (default: transactions.db in working dir)
# On Railway, set this to a path inside your mounted volume, e.g. /data/transactions.db
DATABASE_PATH=transactions.db
